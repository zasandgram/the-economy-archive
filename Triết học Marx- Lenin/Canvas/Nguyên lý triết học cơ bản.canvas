		{"id":"9ef06ab0e2ca054d","type":"text","text":"Phát triển từ thấp đến cao, chất cũ đến chất mới","x":514,"y":-240,"width":250,"height":60},
		{"id":"639d026cc20528dd","type":"text","text":"Tiến bộ: cải thiện xã hội, hoàn thiện hơn","x":542,"y":-98,"width":250,"height":60},

		{"id":"ff52686f96cc905f","type":"text","text":"Các yếu tố ràng buộc, ảnh hưởng lẫn nhau","x":-940,"y":-341,"width":221,"height":60},
		{"id":"367c5536ed87d5cd","type":"text","text":"Nội dung","x":-600,"y":-190,"width":123,"height":50},
		{"id":"9f104a4dd1b30b28","type":"text","text":"Sự vật liên hệ qua lại, quy định, chuyển hoá lẫn nhau","x":-973,"y":-175,"width":250,"height":60},
		{"id":"1090c1ef48df0b84","type":"text","text":"Ý nghĩa phương pháp luận","x":-719,"y":-20,"width":255,"height":50},
		{"id":"6ff0d3da4ed8e45c","type":"text","text":"Xem xét toàn diện","x":-982,"y":114,"width":202,"height":50},
		{"id":"1d0c6f70647cdab9","type":"text","text":"Rút ra mối liên hệ tất yếu","x":-872,"y":176,"width":252,"height":50},
